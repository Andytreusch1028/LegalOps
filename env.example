# Database Configuration
POSTGRES_DB=legalops
POSTGRES_USER=legalops_user
POSTGRES_PASSWORD=legalops_password
DATABASE_URL=postgresql://legalops_user:legalops_password@localhost:5432/legalops

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Application Configuration
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-change-in-production
API_URL=http://localhost:8000
APP_NAME=Legal Ops Platform

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Services
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# File Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=legalops-documents
AWS_REGION=us-east-1

# Monitoring
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# Payment Processing
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Florida Sunbiz Integration
SUNBIZ_API_KEY=your-sunbiz-api-key
SUNBIZ_API_URL=https://api.sunbiz.org

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE_MB=10
